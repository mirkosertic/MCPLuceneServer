### --- Document Details ---

# getDocumentDetails — retrieve all stored fields and content by file path
POST http://localhost:9000/mcp/message
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "id": 37,
  "method": "tools/call",
  "params": {
    "name": "getDocumentDetails",
    "arguments": {
      "filePath": "/userdata/documents/contracts/mietvertrag-2024.pdf"
    }
  }
}

### --- Index Administration ---

# unlockIndex — remove write.lock (dangerous recovery, requires explicit confirmation)
POST http://localhost:9000/mcp/message
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "id": 38,
  "method": "tools/call",
  "params": {
    "name": "unlockIndex",
    "arguments": {
      "confirm": true
    }
  }
}

###

# optimizeIndex — full optimization to a single segment (long-running background)
POST http://localhost:9000/mcp/message
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "id": 39,
  "method": "tools/call",
  "params": {
    "name": "optimizeIndex",
    "arguments": {
      "maxSegments": 1
    }
  }
}

###

# optimizeIndex — partial optimization to 3 segments
POST http://localhost:9000/mcp/message
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "id": 40,
  "method": "tools/call",
  "params": {
    "name": "optimizeIndex",
    "arguments": {
      "maxSegments": 3
    }
  }
}

###

# purgeIndex — soft purge (deleteAll, keeps index directory)
POST http://localhost:9000/mcp/message
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "id": 41,
  "method": "tools/call",
  "params": {
    "name": "purgeIndex",
    "arguments": {
      "confirm": true,
      "fullPurge": false
    }
  }
}

###

# purgeIndex — full purge with index file deletion (reclaims disk space)
POST http://localhost:9000/mcp/message
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "id": 42,
  "method": "tools/call",
  "params": {
    "name": "purgeIndex",
    "arguments": {
      "confirm": true,
      "fullPurge": true
    }
  }
}

