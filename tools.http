### --- Directory Configuration ---

# listCrawlableDirectories — show all configured directories
POST http://localhost:9000/mcp/message
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "id": 25,
  "method": "tools/call",
  "params": {
    "name": "listCrawlableDirectories",
    "arguments": {}
  }
}

###

# addCrawlableDirectory — add directory without immediate crawl
POST http://localhost:9000/mcp/message
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "id": 26,
  "method": "tools/call",
  "params": {
    "name": "addCrawlableDirectory",
    "arguments": {
      "path": "/userdata/documents/reports"
    }
  }
}

###

# addCrawlableDirectory — add directory and crawl immediately
POST http://localhost:9000/mcp/message
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "id": 27,
  "method": "tools/call",
  "params": {
    "name": "addCrawlableDirectory",
    "arguments": {
      "path": "/userdata/documents/contracts",
      "crawlNow": true
    }
  }
}

###

# removeCrawlableDirectory — remove a directory from the crawler config
POST http://localhost:9000/mcp/message
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "id": 28,
  "method": "tools/call",
  "params": {
    "name": "removeCrawlableDirectory",
    "arguments": {
      "path": "/userdata/documents/reports"
    }
  }
}

