  "method": "tools/call",
  "params": {
    "name": "getIndexStats",
    "arguments": {}
  }
}

### --- Crawler Tools ---

# startCrawl — incremental crawl (new/changed files only)
POST http://localhost:9000/mcp/message
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "id": 19,
  "method": "tools/call",
  "params": {
    "name": "startCrawl",
    "arguments": {
      "fullReindex": false
    }
  }
}

###

# startCrawl — full reindex (purge and reindex all documents)
POST http://localhost:9000/mcp/message
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "id": 20,
  "method": "tools/call",
  "params": {
    "name": "startCrawl",
    "arguments": {
      "fullReindex": true
    }
  }
}

###

# getCrawlerStats — real-time throughput and per-directory progress
