# MCP Lucene Server — HTTP Streaming API Examples
# Uses the MCP Streamable HTTP transport (JSON-RPC 2.0 over HTTP POST)
# Endpoint: POST http://localhost:9000/mcp/message
# Compatible with IntelliJ HTTP Client and VS Code REST Client

### --- Session Initialization ---

# Initialize MCP session (run this first to establish protocol handshake)
POST http://localhost:9000/mcp/message
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "id": 1,
  "method": "initialize",
  "params": {
    "protocolVersion": "2025-03-26",
    "capabilities": {},
    "clientInfo": { "name": "http-client", "version": "1.0" }
  }
}

### --- Search Tools ---

# Simple keyword search
POST http://localhost:9000/mcp/message
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "id": 2,
  "method": "tools/call",
  "params": {
    "name": "search",
    "arguments": {
      "query": "Mietvertrag"
    }
  }
}

###

# Phrase search with quotes
POST http://localhost:9000/mcp/message
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "id": 3,
  "method": "tools/call",
  "params": {
    "name": "search",
    "arguments": {
      "query": "\"domain driven design\""
    }
  }
}

###

# Boolean search with AND/OR
POST http://localhost:9000/mcp/message
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "id": 4,
  "method": "tools/call",
  "params": {
    "name": "search",
    "arguments": {
      "query": "(contract OR Vertrag) AND payment"
    }
  }
}

###

# Wildcard search — prefix (suffix wildcard)
POST http://localhost:9000/mcp/message
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "id": 5,
  "method": "tools/call",
  "params": {
    "name": "search",
    "arguments": {
      "query": "report*"
    }
  }
}

###

# Wildcard search — leading wildcard (matches compound words)
POST http://localhost:9000/mcp/message
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "id": 6,
  "method": "tools/call",
  "params": {
    "name": "search",
    "arguments": {
      "query": "*vertrag"
    }
  }
}

###

# Search with language filter (eq operator)
POST http://localhost:9000/mcp/message
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "id": 7,
  "method": "tools/call",
  "params": {
    "name": "search",
    "arguments": {
      "query": "Arbeitsvertrag",
      "filters": [
        { "field": "language", "operator": "eq", "value": "de" }
      ]
    }
  }
}

###

# Search with date range filter (range operator)
POST http://localhost:9000/mcp/message
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "id": 8,
  "method": "tools/call",
  "params": {
    "name": "search",
    "arguments": {
      "query": "invoice",
      "filters": [
        { "field": "modified_date", "operator": "range", "from": "2024-01-01", "to": "2024-12-31" }
      ]
    }
  }
}

###

# Search with multiple filters — language AND file_type
POST http://localhost:9000/mcp/message
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "id": 9,
  "method": "tools/call",
  "params": {
    "name": "search",
    "arguments": {
      "query": "Bericht",
      "filters": [
        { "field": "language", "operator": "eq", "value": "de" },
        { "field": "file_type", "operator": "eq", "value": "application/pdf" }
      ]
    }
  }
}

###

# Search with in operator — multiple accepted values
POST http://localhost:9000/mcp/message
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "id": 10,
  "method": "tools/call",
  "params": {
    "name": "search",
    "arguments": {
      "query": "annual report",
      "filters": [
        { "field": "file_extension", "operator": "in", "values": ["pdf", "docx", "xlsx"] }
      ]
    }
  }
}

###

# Search with pagination — page 2, 5 results per page
POST http://localhost:9000/mcp/message
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "id": 11,
  "method": "tools/call",
  "params": {
    "name": "search",
    "arguments": {
      "query": "project plan",
      "page": 1,
      "pageSize": 5
    }
  }
}

###

# Search sorted by modified_date descending (newest first)
POST http://localhost:9000/mcp/message
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "id": 12,
  "method": "tools/call",
  "params": {
    "name": "search",
    "arguments": {
      "query": "meeting notes",
      "sortBy": "modified_date",
      "sortOrder": "desc"
    }
  }
}

###

# Match-all — list all documents (null query)
POST http://localhost:9000/mcp/message
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "id": 13,
  "method": "tools/call",
  "params": {
    "name": "search",
    "arguments": {
      "query": null,
      "pageSize": 20
    }
  }
}

###

# Search with useVectorSearch disabled — BM25 only
POST http://localhost:9000/mcp/message
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "id": 14,
  "method": "tools/call",
  "params": {
    "name": "search",
    "arguments": {
      "query": "software architecture",
      "useVectorSearch": false
    }
  }
}

### --- Profile Query Tools ---

# profileQuery — Level 1 only (fast, query structure and term stats)
POST http://localhost:9000/mcp/message
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "id": 15,
  "method": "tools/call",
  "params": {
    "name": "profileQuery",
    "arguments": {
      "query": "Mietvertrag Kündigung"
    }
  }
}

###

# profileQuery — Full analysis (all flags, up to 10 doc explanations)
POST http://localhost:9000/mcp/message
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "id": 16,
  "method": "tools/call",
  "params": {
    "name": "profileQuery",
    "arguments": {
      "query": "invoice payment",
      "filters": [
        { "field": "language", "operator": "eq", "value": "en" }
      ],
      "analyzeFilterImpact": true,
      "analyzeDocumentScoring": true,
      "analyzeFacetCost": true,
      "maxDocExplanations": 10
    }
  }
}

###

# profileQuery — with vector search disabled
POST http://localhost:9000/mcp/message
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "id": 17,
  "method": "tools/call",
  "params": {
    "name": "profileQuery",
    "arguments": {
      "query": "domain driven design",
      "analyzeDocumentScoring": true,
      "useVectorSearch": false
    }
  }
}

